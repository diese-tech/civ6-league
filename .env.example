# Copy this to .env for local development.
# Vercel must define production values in Project Settings > Environment Variables.

# Neon PostgreSQL. Use the pooled Neon URL for Vercel runtime.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Discord OAuth (optional unless Discord sign-in is enabled)
# DISCORD_CLIENT_ID="your-discord-client-id"
# DISCORD_CLIENT_SECRET="your-discord-client-secret"

# Bot/API shared secrets
# BOT_SYNC_SECRET="shared-secret-for-discord-bot-sync"
# BLOG_PASSWORD="admin-password-for-blog-and-rules-editor"

# Optional public Discord links
# NEXT_PUBLIC_DISCORD_SERVER_ID="your-server-id"
# NEXT_PUBLIC_DISCORD_INVITE_URL="https://discord.gg/your-invite"
