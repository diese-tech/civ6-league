# ─── CIV VI LEAGUE — ENVIRONMENT VARIABLES ──────────────────────────────────
# Copy this to .env and fill in your values

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (local development — works out of the box)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production — uncomment and use this instead)
# DATABASE_URL="postgresql://user:password@host:5432/civ6league?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ── Discord OAuth (optional) ────────────────────────────────────────────────
# Create an app at https://discord.com/developers/applications
# Set redirect URL to: http://localhost:3000/api/auth/callback/discord
# DISCORD_CLIENT_ID="your-discord-client-id"
# DISCORD_CLIENT_SECRET="your-discord-client-secret"

# ── Discord Widget (optional) ───────────────────────────────────────────────
# Your Discord server ID for the embed widget
# NEXT_PUBLIC_DISCORD_SERVER_ID="your-server-id"
# NEXT_PUBLIC_DISCORD_INVITE_URL="https://discord.gg/your-invite"
